{
  "name": "velync",
  "version": "1.0.0",
  "description": "Velync — SaaS Integration Platform. Prebuilt sync apps for your tools.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build:dashboard": "node scripts/build-dashboard.js",
    "test": "node --test test/unit.test.js",
    "test:rules": "npx firebase emulators:exec --only firestore \"node --test test/firestore-rules.test.js\"",
    "test:engine": "npx firebase emulators:exec --only firestore \"node --test test/engine.test.js\"",
    "test:admin": "npx firebase emulators:exec --only firestore \"node --test test/admin-stats.test.js\"",
    "test:admin-platforms": "npx firebase emulators:exec --only firestore \"node --test test/admin-platforms.test.js\"",
    "test:logs-fixes": "npx firebase emulators:exec --only firestore \"node --test test/logs-fixes.test.js\"",
    "test:connections-fixes": "npx firebase emulators:exec --only firestore \"node --test test/connections-fixes.test.js\"",
    "test:notifications": "npx firebase emulators:exec --only firestore \"node --test test/notifications.test.js\"",
    "test:sync-configs-fixes": "npx firebase emulators:exec --only firestore \"node --test test/sync-configs-fixes.test.js\"",
    "test:connector-resolution": "npx firebase emulators:exec --only firestore \"node --test test/connector-resolution.test.js\"",
    "test:billing-fixes": "npx firebase emulators:exec --only firestore \"node --test test/billing-fixes.test.js\"",
    "test:workspace-fixes": "npx firebase emulators:exec --only firestore \"node --test test/workspace-fixes.test.js\"",
    "test:profile-settings-fixes": "npx firebase emulators:exec --only firestore \"node --test test/profile-settings-fixes.test.js\"",
    "test:auth-fail-closed": "node --test test/auth-fail-closed.test.js",
    "test:config-deletion": "npx firebase emulators:exec --only firestore \"node --test test/config-deletion.test.js\"",
    "test:dispatcher": "npx firebase emulators:exec --only firestore \"node --test test/dispatcher.test.js\"",
    "test:superadmin": "npx firebase emulators:exec --only firestore \"node --test test/superadmin.test.js\"",
    "test:admin-plans-fixes": "npx firebase emulators:exec --only firestore \"node --test test/admin-plans-fixes.test.js\"",
    "test:all": "npm test && npm run test:rules && npm run test:engine && npm run test:admin && npm run test:admin-platforms && npm run test:logs-fixes && npm run test:connections-fixes && npm run test:notifications && npm run test:sync-configs-fixes && npm run test:connector-resolution && npm run test:billing-fixes && npm run test:workspace-fixes && npm run test:profile-settings-fixes && npm run test:auth-fail-closed && npm run test:config-deletion && npm run test:dispatcher && npm run test:superadmin && npm run test:admin-plans-fixes"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^2.10.0",
    "@notionhq/client": "^5.22.0",
    "axios": "^1.18.1",
    "cron-parser": "^5.6.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^14.0.0",
    "form-data": "^4.0.6",
    "helmet": "^8.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "stripe": "^17.0.0",
    "uuid": "^14.0.1"
  },
  "overrides": {
    "jose": "^5.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "esbuild": "^0.28.1"
  }
