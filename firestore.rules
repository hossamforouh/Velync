rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    function isWorkspaceMember(workspaceId) {
      return request.auth != null && (
        // Default solo workspace: the app uses the owner's own uid AS the workspaceId
        // and never creates a separate `workspaces/{id}` document for solo users
        // (see auth.js `resolvedWsId = workspaceId || uid`, and app.js's
        // read-then-create-if-missing default-workspace flow on login). This branch
        // must stay allowed even when the document doesn't exist yet — do NOT wrap
        // it in exists(...), or first-login/solo-user access breaks entirely.
        request.auth.uid == workspaceId ||
        // Real shared/multi-member workspace: an explicit doc exists with owner/members.
        (
          exists(/databases/$(database)/documents/workspaces/$(workspaceId)) &&
          (
            request.auth.uid == get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId ||
            request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.get('members', [])
          )
        )
      );
    }

    function isWorkspaceMemberFromField() {
      return request.auth != null && resource != null && resource.data.workspaceId != null && (
        request.auth.uid == resource.data.workspaceId ||
        (
          exists(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)) &&
          (
            request.auth.uid == get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.ownerId ||
            request.auth.uid in get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.get('members', [])
          )
        )
      );
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isPendingInvite(workspaceId) {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.get('invitedEmails', []);
    }

    // ─── Superadmins ──────────────────────────────────────────
    match /superadmins/{uid} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── Users ────────────────────────────────────────────────
    match /users/{userId} {
      // Readable by the user themselves, a superadmin, or anyone who shares
      // the same workspaceId (covers the member-list UI reading co-members'
      // profiles) — not literally any signed-in user, which was the previous
      // rule and let any authenticated account read anyone else's profile.
      allow read: if isOwner(userId) || isSuperAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('workspaceId', null) != null
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('workspaceId', null)
               == resource.data.get('workspaceId', null));
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string;
      // Use diff(...).affectedKeys() — NOT keys().hasOnly(...) — because on
      // an update request.resource.data is the FULL post-update document, so
      // a doc that already has authVersion/lastSessionRevokedAt set (by the
      // Admin-SDK-only /api/settings/revoke-sessions route) would fail every
      // subsequent client update if those fields were checked against the
      // full key set. diff().affectedKeys() only looks at what THIS write
      // actually changes, which also cleanly excludes authVersion/
      // lastSessionRevokedAt from what a client may change (server-
      // authoritative session-security bookkeeping) without breaking updates
      // to documents that already carry those fields.
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['id', 'name', 'email', 'workspaceName', 'notificationPrefs', 'workspaceId', 'createdAt', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    // ─── Workspaces ───────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId) || isPendingInvite(workspaceId);
      // Previously only checked hasAny(['name']) — no allowlist and no value
      // validation, so a client could set planId to 'pro'/'business' (or
      // forge lsCustomerId/lsSubscriptionId/etc.) directly on creation and
      // grant itself a paid plan for free, or claim ownership/membership on
      // another user's behalf. Locked down to exactly the fields the
      // client's own signup flow writes (see ensureWorkspaceDoc() in
      // app.js), with planId pinned to 'free' — any other plan can only be
      // reached through the real billing flow (server-side, Admin SDK).
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['id', 'name', 'ownerId', 'members', 'invitedEmails', 'planId'])
        && request.resource.data.keys().hasAny(['name'])
        && request.auth.uid == request.resource.data.ownerId
        && request.resource.data.members == [request.auth.uid]
        && (!('planId' in request.resource.data) || request.resource.data.planId == 'free');
      // Owner may edit only these fields. Use affectedKeys().hasOnly(...) — NOT keys().hasAny(...) —
      // because on an update request.resource.data is the full post-update doc, so hasAny would
      // always pass (name/ownerId always present) and let billing fields like planId/lsCustomerId
      // through. Billing fields are written server-side (Admin SDK) only.
      allow update: if isSuperAdmin() || (
        request.auth.uid == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['name', 'description', 'members', 'invitedEmails', 'ownerId', 'updatedAt'])
      );
      allow delete: if false;

      // Sync configs under a workspace
      match /sync_configs/{configId} {
        allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId);
        // Server-only: create/update/delete must go through
        // POST/PUT/DELETE /api/sync-configs — that's the only place
        // enforcePlanLimits() (max active configs, connector tiers, min sync
        // interval) actually runs. A direct client write here would bypass
        // all of it, and a client-side delete would also orphan the
        // sync_mappings subcollection (Firestore doesn't cascade deletes).
        allow write: if false;

        // Sync mappings subcollection
        match /sync_mappings/{mappingId} {
          allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId);
          allow write: if isSuperAdmin() || isWorkspaceMember(workspaceId);
        }
      }
    }

    // Collection-group scope for sync_configs (required for collectionGroup queries)
    match /{path=**}/sync_configs/{configId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Top-level collections with workspaceId field
    match /execution_logs/{logId} {
      allow read: if isSuperAdmin() || isWorkspaceMemberFromField();
      allow write: if false;
    }

    // Writes go through backend routes only (src/api/routes/auth.js's OAuth
    // exchange and src/api/routes/connections.js for manual connections) —
    // secrets are encrypted server-side into `credentials`, never stored in
    // plaintext on this client-readable collection.
    match /connected_accounts/{accountId} {
      allow read: if isSuperAdmin() || isWorkspaceMemberFromField();
      allow write: if false;
    }

    // ─── Mail collection (for firestore-send-email extension) ──
    // Server-only: every email send (invites, billing, sync-failure/admin
    // alerts) now goes through a backend route using the Admin SDK. A
    // client-writable `to`/`message` doc with no relation to a real invite
    // or event was an open email-relay abuse vector.
    match /mail/{mailId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── Public marketplace data ──────────────────────────────
    match /platforms/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /integrations/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Platform OAuth client secrets (Admin SDK only) ───────
    // Split out of `platforms` because that collection is readable by any
    // authenticated user (needed for the connect-flow UI) — secrets must
    // never live in a doc with that read rule.
    match /platform_secrets/{platformId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── Plans (publicly readable, backend/admin-writable) ───
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── App settings ─────────────────────────────────────────
    match /app_settings/{documentId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Activity logs ────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['action', 'timestamp']);
      allow update, delete: if isSuperAdmin();
    }

    // ─── Credentials ──────────────────────────────────────────
    match /credentials/{documentId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── API Keys (server-side only via Admin SDK) ────────────
    match /api_keys/{keyId} {
      allow read: if false;
      allow write: if false;
    }

    // ─── Usage tracking (server-side only via Admin SDK) ──────
    // Cost/usage data feeds pricing decisions — a client-writable path here
    // would let users forge their own usage records; reads are admin-panel
    // concerns served through /api/admin/usage.
    match /usage_events/{eventId} {
      allow read: if false;
      allow write: if false;
    }
    match /usage_summaries/{summaryId} {
      allow read: if false;
      allow write: if false;
    }
    match /usage_meta/{documentId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
