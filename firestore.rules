rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    function isWorkspaceMember(workspaceId) {
      return request.auth != null && (
        request.auth.uid == workspaceId ||
        request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members
      );
    }

    function isWorkspaceMemberFromField() {
      return request.auth != null && resource != null && resource.data.workspaceId != null && (
        request.auth.uid == resource.data.workspaceId ||
        request.auth.uid in get(/databases/$(database)/documents/workspaces/$(resource.data.workspaceId)).data.members
      );
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isPendingInvite(workspaceId) {
      return request.auth != null
        && request.auth.token.email != null
        && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.invitedEmails
        && request.auth.token.email in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.invitedEmails;
    }

    // ─── Superadmins ──────────────────────────────────────────
    match /superadmins/{uid} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── Users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string;
      allow update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['name', 'email', 'notificationPrefs', 'workspaceId', 'authVersion', 'lastSessionRevokedAt', 'updatedAt']);
      allow delete: if isOwner(userId);
    }

    // ─── Workspaces ───────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId) || isPendingInvite(workspaceId);
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['name']);
      allow update: if isSuperAdmin() || request.auth.uid == workspaceId
        && request.resource.data.keys().hasAny(['name', 'description', 'members', 'invitedEmails', 'ownerId']);
      allow delete: if false;

      // Sync configs under a workspace
      match /sync_configs/{configId} {
        allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId);
        allow create: if isWorkspaceMember(workspaceId)
          && request.resource.data.keys().hasAny(['description', 'platform1', 'platform2']);
        allow update: if isWorkspaceMember(workspaceId);
        allow delete: if isWorkspaceMember(workspaceId);

        // Sync mappings subcollection
        match /sync_mappings/{mappingId} {
          allow read: if isSuperAdmin() || isWorkspaceMember(workspaceId);
          allow write: if isSuperAdmin() || isWorkspaceMember(workspaceId);
        }
      }
    }

    // Collection-group scope for sync_configs (required for collectionGroup queries)
    match /{path=**}/sync_configs/{configId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    // Top-level collections with workspaceId field
    match /execution_logs/{logId} {
      allow read: if isSuperAdmin() || isWorkspaceMemberFromField();
      allow write: if false;
    }

    match /connected_accounts/{accountId} {
      allow read: if isSuperAdmin() || isWorkspaceMemberFromField();
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['provider', 'userId'])
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/connected_accounts/$(accountId)).data.userId == request.auth.uid;
    }

    // ─── Mail collection (for firestore-send-email extension) ──
    match /mail/{mailId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['to', 'message']);
      allow update, delete: if false;
    }

    // ─── Public marketplace data ──────────────────────────────
    match /platforms/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /integrations/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── App settings ─────────────────────────────────────────
    match /app_settings/{documentId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Activity logs ────────────────────────────────────────
    match /activity_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['action', 'timestamp']);
      allow update, delete: if isSuperAdmin();
    }

    // ─── Credentials ──────────────────────────────────────────
    match /credentials/{documentId} {
      allow read: if request.auth != null && request.auth.uid == documentId;
      allow write: if false;
    }

    // ─── API Keys (server-side only via Admin SDK) ────────────
    match /api_keys/{keyId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
