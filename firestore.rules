rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null 
        && request.auth.token.email == 'hossamforouh@icloud.com';
    }

    // Securely check if the user is a member of the given workspace
    function isWorkspaceMember(workspaceId) {
      // Allow if it is their personal default workspace (fallback), OR if they are in the workspace's members array
      return (request.auth.uid == workspaceId) || 
             (request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.members);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    match /workspaces/{workspaceId} {
      // Members or invited users can read.
      allow read: if isSuperAdmin() || (request.auth != null && (
        request.auth.uid == workspaceId ||
        (resource != null && 'members' in resource.data && request.auth.uid in resource.data.members) || 
        (resource != null && 'invitedEmails' in resource.data && request.auth.token.email in resource.data.invitedEmails)
      ));
      // Anyone can create their own workspace
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      // Owner can update OR an invited user can update to add themselves to members
      allow update: if isSuperAdmin() || (request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        (
          resource != null && 'invitedEmails' in resource.data && 
          request.auth.token.email in resource.data.invitedEmails && 
          request.auth.uid in request.resource.data.members
        )
      ));

      // Hierarchical Sub-collections
      match /sync_configs/{configId} {
        allow read, update, delete: if request.auth != null && (isWorkspaceMember(workspaceId) || isSuperAdmin());
        allow create: if request.auth != null && (isWorkspaceMember(workspaceId) || isSuperAdmin());

        match /sync_mappings/{mappingId} {
          allow read, write: if request.auth != null && (isWorkspaceMember(workspaceId) || isSuperAdmin());
        }
      }
    }

    match /invitations/{inviteId} {
      // The invited user OR a workspace member can read
      allow read: if request.auth != null && (request.auth.token.email == resource.data.email || isWorkspaceMember(resource.data.workspaceId));
      allow create: if request.auth != null && isWorkspaceMember(request.resource.data.workspaceId);
      allow delete: if request.auth != null && (request.auth.token.email == resource.data.email || isWorkspaceMember(resource.data.workspaceId));
    }

    // Global App Settings (e.g. WhatsApp number)
    match /app_settings/{documentId} {
      allow read: if true; // Publicly readable
      allow write: if isSuperAdmin(); // Only editable by Super Admin
    }

    // Marketplace integrations
    match /integrations/{documentId} {
      allow read: if true; // Publicly readable
      allow write: if isSuperAdmin(); // Only editable by Super Admin
    }

    // Platforms definitions
    match /platforms/{documentId} {
      allow read: if true; // Publicly readable
      allow write: if isSuperAdmin(); // Only editable by Super Admin
    }

    // Connected OAuth accounts
    match /connected_accounts/{accountId} {
      allow read, update, delete: if request.auth != null
        && (isWorkspaceMember(resource.data.workspaceId) || isSuperAdmin());
      allow create: if request.auth != null
        && (isWorkspaceMember(request.resource.data.workspaceId) || isSuperAdmin());
    }

    // User credentials (secure OAuth tokens)
    match /credentials/{documentId} {
      allow read, write: if request.auth != null && request.auth.uid == documentId;
    }

    // User UI Connections
    match /connections/{connectionId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Execution logs
    match /execution_logs/{logId} {
      allow read: if request.auth != null
        && (isWorkspaceMember(resource.data.workspaceId) || isSuperAdmin());
      allow write: if false;
    }

    // Trigger Email Extension
    match /mail/{mailId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
