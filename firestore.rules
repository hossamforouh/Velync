rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Collection-group scope for sync_configs (required for collectionGroup queries)
    match /{path=**}/sync_configs/{configId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /workspaces/{workspaceId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /sync_configs/{configId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /execution_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /connected_accounts/{accountId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /platforms/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /integrations/{documentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /app_settings/{documentId} {
      allow read: if true;
      allow write: if false;
    }

    match /activity_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
