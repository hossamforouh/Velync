# ==============================================================================
# Notion & TickTick Integration Environment Variables Template
# ==============================================================================

# Notion Configuration
# ------------------------------------------------------------------------------
# Create an integration at https://www.notion.so/my-integrations and share the
# database with your integration.
NOTION_INTEGRATION_TOKEN=secret_your_notion_internal_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# TickTick Configuration
# ------------------------------------------------------------------------------
# Register an app in TickTick Developer Platform: https://developer.ticktick.com/
TICKTICK_CLIENT_ID=your_ticktick_client_id_here
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret_here

# For API endpoints authentication / Direct Login alternative
TICKTICK_USERNAME=your_ticktick_username_here
TICKTICK_PASSWORD=your_ticktick_password_here

# Optional: If you already have a pre-generated OAuth Access Token
TICKTICK_ACCESS_TOKEN=your_ticktick_oauth_access_token_here

# Optional: Direct session cookie from a browser login. Useful if automated
# signon fails due to 500 error, Cloudflare, or captcha.
TICKTICK_COOKIE=your_ticktick_session_cookie_here
# Integration Service Settings
# ------------------------------------------------------------------------------
# Log level: info, debug, error
LOG_LEVEL=info
