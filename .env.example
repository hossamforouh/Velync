# ==============================================================================
# Notion & TickTick Integration Environment Variables Template
# ==============================================================================

# Notion Configuration
# ------------------------------------------------------------------------------
# Create an integration at https://www.notion.so/my-integrations and share the
# database with your integration.
NOTION_INTEGRATION_TOKEN=secret_your_notion_internal_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# TickTick Configuration
# ------------------------------------------------------------------------------
# Register an app in TickTick Developer Platform: https://developer.ticktick.com/
TICKTICK_CLIENT_ID=your_ticktick_client_id_here
TICKTICK_CLIENT_SECRET=your_ticktick_client_secret_here

# For API endpoints authentication / Direct Login alternative
TICKTICK_USERNAME=your_ticktick_username_here
TICKTICK_PASSWORD=your_ticktick_password_here

# Optional: If you already have a pre-generated OAuth Access Token
TICKTICK_ACCESS_TOKEN=your_ticktick_oauth_access_token_here

# Optional: Direct session cookie from a browser login. Useful if automated
# signon fails due to 500 error, Cloudflare, or captcha.
TICKTICK_COOKIE=your_ticktick_session_cookie_here
# API Configuration
# ------------------------------------------------------------------------------

# Superadmin status is determined by the `superadmins` Firestore collection
# (doc id = uid) — see scripts/seed-superadmin.js. No env var needed.

# Timeout (in ms) for outgoing requests to external APIs (TickTick, Notion, OAuth)
EXTERNAL_API_TIMEOUT=30000

# Integration Service Settings
# ------------------------------------------------------------------------------
# Log level: info, debug, error
LOG_LEVEL=info

# Scheduler (Decision 3 — external scheduling)
# ------------------------------------------------------------------------------
# SCHEDULER_MODE: 'internal' (default, in-process node-cron) or 'external'
#   (driven by Cloud Scheduler → POST /api/internal/scheduler/tick).
# SCHEDULER_SECRET: shared secret required on the internal scheduler endpoints.
# See infrastructure/external-scheduler-setup.md
SCHEDULER_MODE=internal
SCHEDULER_SECRET=

# Lemon Squeezy (billing)
# ------------------------------------------------------------------------------
# API key: Lemon Squeezy dashboard → Settings → API. Use a Test Mode store's
#   key while testing — billing endpoints return 503 until this is set.
# STORE_ID: Settings → General (or the store switcher URL) for the store
#   whose Products/Variants are referenced by each plan's lsVariantIdMonthly/
#   lsVariantIdAnnual fields (set via the Admin Panel's Plans tab).
# WEBHOOK_SECRET: the signing secret shown when you create the webhook
#   endpoint (Settings → Webhooks) pointing at POST /api/billing/webhook.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
