{
  "hosting": {
    "public": "dashboard/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/auth-callback.html",
        "destination": "/auth-callback.html"
      },
      {
        "source": "/privacy.html",
        "destination": "/privacy.html"
      },
      {
        "source": "/google7d74775a46a2ed27.html",
        "destination": "/google7d74775a46a2ed27.html"
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "velync-backend",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.9"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
